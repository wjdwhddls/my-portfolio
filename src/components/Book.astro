---
/**
 * 단일 책 — 책장에 꽂혀있는 모습(책등만 보임).
 * <button> 시맨틱으로 키보드 포커스/Enter/Space 기본 지원.
 *
 * 시각 표현은 모두 CSS 변수로 주입해 bookshelf.css 한 곳에서 관리한다.
 */
import type { Project } from '../data/projects';
import {
  resolveLeather,
  resolveSpineWidth,
  leatherPalettes,
  bookId,
  BOOK_HEIGHT,
} from '../data/bookshelf';

export interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;
const leather = resolveLeather(project, index);
const palette = leatherPalettes[leather];
const width = resolveSpineWidth(project);
const spineTitle = project.book?.spineTitle ?? project.title;
const spineSubtitle = project.book?.spineSubtitle ?? project.context ?? '';
const id = bookId(index);

// 인라인 CSS 변수: 책별로 다른 가죽 팔레트와 크기를 부여
const style = [
  `--book-w:${width}px`,
  `--book-h:${BOOK_HEIGHT}px`,
  `--leather-base:${palette.base}`,
  `--leather-deep:${palette.deep}`,
  `--leather-high:${palette.high}`,
  `--gold:${palette.gold}`,
  `--enter-delay:${index * 80}ms`,
].join(';');
---

<button
  class="book"
  type="button"
  data-project-id={id}
  aria-haspopup="dialog"
  aria-controls="book-modal"
  style={style}
>
  <span class="sr-only">{project.title} 프로젝트 자세히 보기</span>
  <span class="book__spine" aria-hidden="true">
    <span class="book__spine-band book__spine-band--top"></span>
    <span class="book__spine-rule book__spine-rule--top"></span>
    <span class="book__spine-title">{spineTitle}</span>
    {spineSubtitle && <span class="book__spine-sub">{spineSubtitle}</span>}
    <span class="book__spine-rule book__spine-rule--bottom"></span>
    <span class="book__spine-band book__spine-band--bottom"></span>
    <span class="book__spine-emboss">{project.book?.monogram ?? project.emoji}</span>
    <span class="book__spine-noise"></span>
  </span>
</button>
