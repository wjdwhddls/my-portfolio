---
/**
 * Hero 섹션 — AI Engineer / Backend Developer 정체성으로 재구성.
 * - 좌측: 인사, 이름(gradient), 타이핑, 본문, CTA(프로젝트 보기 / 연락하기 / 이력서 다운로드)
 * - 우측: 코드 에디터 mock — name/role/stack/focus 4개 키만 노출하는 간결 버전
 * - 배경: 파티클 canvas + 두 개의 부유 blob
 */
import { profile } from '../data/profile';
import ParticleCanvas from './client/ParticleCanvas.astro';
import TypingText from './client/TypingText.astro';
---

<section
  id="home"
  class="min-h-screen flex items-center justify-center relative overflow-hidden pt-20"
>
  <!-- 파티클 -->
  <ParticleCanvas />

  <!-- 배경 그라데이션 blob -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute top-20 right-0 w-96 h-96 bg-primary/10 rounded-full blur-3xl float-animate"></div>
    <div
      class="absolute bottom-20 left-0 w-72 h-72 bg-primary/5 rounded-full blur-3xl"
      style="animation: float 4s ease-in-out infinite 1s;"
    ></div>
  </div>

  <div class="max-w-6xl mx-auto px-4 py-20 relative z-10">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- 좌측 -->
      <div class="space-y-6 fade-in-up">
        <p class="text-primary-hover font-medium text-lg">안녕하세요 👋</p>

        <h1 class="text-5xl md:text-7xl font-bold leading-tight tracking-tightish">
          <span class="gradient-text">{profile.name}</span>
        </h1>

        <div class="h-16 flex items-center">
          <span class="text-2xl md:text-3xl text-ink-muted">
            <TypingText phrases={profile.typingPhrases} />
          </span>
        </div>

        <p class="text-ink-muted text-lg leading-relaxed max-w-lg">
          {profile.intro}
        </p>

        <div class="flex flex-wrap gap-3 pt-8 slide-in-left" style="animation-delay: 0.3s;">
          <a
            href="#projects"
            class="magnetic-btn btn-ripple px-8 py-3 bg-primary hover:bg-primary-hover rounded-lg font-medium transition-colors"
          >
            프로젝트 보기
          </a>
          <a
            href="#contact"
            class="magnetic-btn btn-ripple px-8 py-3 border border-primary text-primary-hover hover:bg-primary/10 rounded-lg font-medium transition-colors"
          >
            연락하기
          </a>
          <a
            href={`${import.meta.env.BASE_URL}resume.pdf`}
            download
            class="magnetic-btn btn-ripple px-8 py-3 border border-border text-ink-muted hover:text-ink hover:border-primary rounded-lg font-medium transition-colors inline-flex items-center gap-2"
          >
            이력서
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
          </a>
        </div>
      </div>

      <!-- 우측: 코드 에디터 mock -->
      <div class="hidden md:flex justify-center items-center">
        <div class="relative w-full max-w-md">
          <div class="absolute inset-0 bg-gradient-to-br from-primary to-accent rounded-2xl blur-2xl opacity-15 float-animate"></div>
          <div class="glass rounded-2xl overflow-hidden">
            <div class="flex items-center gap-2 px-4 py-3 border-b border-border/50">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
                <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
              </div>
              <span class="text-xs text-ink-subtle ml-2">profile.ts</span>
            </div>

            <div class="code-editor p-4 space-y-1">
              <div class="flex code-line" style="animation-delay: 0.2s;">
                <span class="line-number">1</span>
                <span>
                  <span class="code-keyword">const</span>{' '}
                  <span class="code-variable">developer</span> ={' '}
                  <span class="code-bracket">{'{'}</span>
                </span>
              </div>
              <div class="flex code-line" style="animation-delay: 0.4s;">
                <span class="line-number">2</span>
                <span>&nbsp;&nbsp;name: <span class="code-string">"정종인"</span>,</span>
              </div>
              <div class="flex code-line" style="animation-delay: 0.6s;">
                <span class="line-number">3</span>
                <span>&nbsp;&nbsp;role: <span class="code-string">"AI Engineer"</span>,</span>
              </div>
              <div class="flex code-line" style="animation-delay: 0.8s;">
                <span class="line-number">4</span>
                <span>
                  &nbsp;&nbsp;stack: [<span class="code-string">"PyTorch"</span>,{' '}
                  <span class="code-string">"TypeScript"</span>,{' '}
                  <span class="code-string">"Python"</span>],
                </span>
              </div>
              <div class="flex code-line" style="animation-delay: 1.0s;">
                <span class="line-number">5</span>
                <span>
                  &nbsp;&nbsp;focus: <span class="code-string">"Multimodal AI + Backend"</span>,
                </span>
              </div>
              <div class="flex code-line" style="animation-delay: 1.2s;">
                <span class="line-number">6</span>
                <span>
                  &nbsp;&nbsp;<span class="code-function">build</span>() <span class="code-bracket">{'{'}</span>
                </span>
              </div>
              <div class="flex code-line" style="animation-delay: 1.4s;">
                <span class="line-number">7</span>
                <span>
                  &nbsp;&nbsp;&nbsp;&nbsp;<span class="code-keyword">return</span>{' '}
                  <span class="code-string">"Real-world AI"</span>;
                </span>
              </div>
              <div class="flex code-line" style="animation-delay: 1.6s;">
                <span class="line-number">8</span>
                <span>&nbsp;&nbsp;<span class="code-bracket">{'}'}</span></span>
              </div>
              <div class="flex code-line" style="animation-delay: 1.8s;">
                <span class="line-number">9</span>
                <span><span class="code-bracket">{'}'}</span>;</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
