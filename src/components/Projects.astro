---
/**
 * Projects 섹션 — projects.ts 데이터 기반.
 * 데스크톱(≥768px)에서는 사실적 야간 서재 씬(좌측 책상 + 우측 책장),
 * 모바일에서는 기존 카드 그리드.
 */
import { projects } from '../data/projects';
import ProjectCard from './ProjectCard.astro';
import CardTilt from './client/CardTilt.astro';
import StudyScene from './StudyScene.astro';
---

<section id="projects" class="py-16 md:py-24 relative">
  <div class="max-w-6xl mx-auto px-4 space-y-12">
    <div class="text-center space-y-4 fade-in-up">
      <h2 class="text-4xl md:text-5xl font-bold">
        <span class="gradient-text">Projects</span>
      </h2>
      <p class="text-ink-muted max-w-2xl mx-auto">
        AI 모델링·백엔드·데이터 분석을 가로지르는 실제 프로젝트들입니다. 모든 코드는 GitHub에서 공개되어 있어요.
      </p>
    </div>

    <!-- 모바일: 기존 카드 그리드 -->
    <div class="grid sm:grid-cols-2 gap-8 md:hidden">
      {
        projects.map((project, i) => (
          <ProjectCard project={project} delay={0.1 * (i + 1)} />
        ))
      }
    </div>
  </div>

  <!-- 데스크톱: 풀 뷰포트 sticky pin 룸. max-w 컨테이너 밖에 두어
       100vw 를 차지하고 스크롤 시 viewport 에 고정된다. -->
  <div class="hidden md:block">
    <div id="cinema-section" class="cinema-section">
      <div class="cinema-pin">
        <div class="cinema-stage">
          <StudyScene projects={projects} />
        </div>
        <div class="cinema-vignette" aria-hidden="true"></div>
      </div>
    </div>
  </div>

  <CardTilt />
</section>
