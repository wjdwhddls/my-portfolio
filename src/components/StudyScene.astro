---
/**
 * 서재 룸 풀뷰 — 1점 투시(perspective) 시점의 어두운 모던 서재.
 *
 * 레이아웃:
 *   - 좌측 벽: 수평으로 긴 책장 (3단, 약식 1점 투시로 살짝 사선)
 *   - 정면 벽 + 천장(어둠) + 바닥(카우하이드 러그)
 *   - 가운데: 검은 미니멀 책상 + 데스크 램프 + 펼친 책 + 메모지
 *   - 책상 앞 의자 (등받이 실루엣)
 *
 * 책 펼침 인터랙션은 좌측 벽 책장의 책을 클릭하는 것으로 유지.
 *
 * 시네마틱 시퀀스(cinematic-room.ts)는 카메라 dolly로 책상 클로즈업(1인칭) →
 * 룸 풀뷰(3인칭) 으로 시점 변화를 만든다.
 */
import type { Project } from '../data/projects';
import Bookshelf from './Bookshelf.astro';

export interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<div class="room room--dark fade-in-up" data-room>
  <!-- 정면 벽 (배경) -->
  <div class="room__wall-back" aria-hidden="true"></div>

  <!-- 천장 (위쪽 어둠) -->
  <div class="room__ceiling" aria-hidden="true"></div>

  <!-- 천장 펜던트 등 — 클릭 시 룸 전체 점등 -->
  <button
    type="button"
    class="room__pendant"
    data-pendant
    aria-label="전등 켜기"
    aria-pressed="false"
  >
    <span class="room__pendant-cord" aria-hidden="true"></span>
    <span class="room__pendant-shade" aria-hidden="true"></span>
    <span class="room__pendant-bulb" aria-hidden="true"></span>
    <span class="room__pendant-glow" aria-hidden="true"></span>
    <span class="room__pendant-cone" aria-hidden="true"></span>
  </button>

  <!-- 좌측 벽 (1점 투시로 살짝 사선) -->
  <div class="room__wall-left" aria-hidden="true">
    <!-- 좌측 벽 위 따뜻한 빛 spot -->
    <div class="room__wall-light"></div>
  </div>

  <!-- 바닥 (카우하이드 러그 포함) -->
  <div class="room__floor" aria-hidden="true">
    <div class="room__rug">
      <!-- 카우하이드 흑백 얼룩 패턴 -->
      <div class="room__rug-patch room__rug-patch--1"></div>
      <div class="room__rug-patch room__rug-patch--2"></div>
      <div class="room__rug-patch room__rug-patch--3"></div>
    </div>
  </div>

  <!-- 좌측 벽 책장 (수평형, 인터랙티브 책 포함) -->
  <div class="room__shelf">
    <Bookshelf projects={projects} variant="wall" />
  </div>

  <!-- 중앙 책상 + 책상 위 소품 -->
  <div class="room__desk" aria-hidden="true">
    <div class="room__desk-top"></div>
    <div class="room__desk-edge"></div>
    <div class="room__desk-leg room__desk-leg--fl"></div>
    <div class="room__desk-leg room__desk-leg--fr"></div>

    <!-- 책상 위 빛 풀(pool) -->
    <div class="room__desk-light"></div>

    <!-- 데스크 램프 (책상 오른쪽 끝) -->
    <div class="room__lamp">
      <div class="room__lamp-base"></div>
      <div class="room__lamp-arm"></div>
      <div class="room__lamp-shade"></div>
      <div class="room__lamp-bulb"></div>
    </div>

    <!-- 펼쳐진 책 (책상 왼쪽) -->
    <div class="room__open-book">
      <div class="room__open-book-page room__open-book-page--left">
        <span class="room__open-book-line"></span>
        <span class="room__open-book-line"></span>
        <span class="room__open-book-line"></span>
        <span class="room__open-book-line"></span>
      </div>
      <div class="room__open-book-page room__open-book-page--right">
        <span class="room__open-book-line"></span>
        <span class="room__open-book-line"></span>
        <span class="room__open-book-line"></span>
      </div>
    </div>

    <!-- 메모지 + 머그 -->
    <div class="room__notepad">
      <span></span><span></span>
    </div>
    <div class="room__mug">
      <div class="room__mug-steam"><span></span><span></span></div>
    </div>
  </div>

  <!-- 책상 의자 (책상 정면에서 등받이만 보임) -->
  <div class="room__chair" aria-hidden="true">
    <div class="room__chair-back"></div>
    <div class="room__chair-seat"></div>
  </div>

  <!-- 비넷 (가장자리 어둠) -->
  <div class="room__vignette" aria-hidden="true"></div>

  <p class="room__hint" aria-hidden="true">
    💡 좌측 책장의 책을 클릭하면 펼쳐집니다
  </p>
</div>

<script>
  (function () {
    const room = document.querySelector('[data-room]');
    const btn  = document.querySelector('[data-pendant]');
    if (!room || !btn) return;

    function setLit(lit: boolean) {
      room!.classList.toggle('room--dark', !lit);
      room!.classList.toggle('room--lit',  lit);
      btn!.setAttribute('aria-pressed', String(lit));
      btn!.setAttribute('aria-label', lit ? '전등 끄기' : '전등 켜기');
    }
    btn.addEventListener('click', () => {
      setLit(btn.getAttribute('aria-pressed') !== 'true');
    });

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!reduce && 'IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting && room.classList.contains('room--dark')) {
            room.classList.add('room--hint');
            io.disconnect();
            break;
          }
        }
      }, { threshold: 0.4 });
      io.observe(room);
    }
  })();
</script>
