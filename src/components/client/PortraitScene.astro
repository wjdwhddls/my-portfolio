---
/**
 * 별자리 초상 마운트 컴포넌트 — Hero 우측 컬럼에서 사용.
 * public/profile.jpg 를 파티클로 재구성 (없으면 JJ 모노그램 폴백).
 * 본체 로직은 scripts/portrait-scene.ts.
 */
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const photoUrl = `${base}profile.jpg`;
---

<div class="portrait-wrap" data-photo={photoUrl}>
  <canvas id="portrait-scene" aria-label="정종인의 별자리 초상" role="img"></canvas>
</div>

<style>
  .portrait-wrap {
    position: relative;
    width: 100%;
    max-width: 420px;
    aspect-ratio: 4 / 5;
    margin: 0 auto;
  }

  #portrait-scene {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
</style>

<script>
  const wrap = document.querySelector<HTMLElement>('.portrait-wrap');
  const canvas = document.getElementById('portrait-scene') as HTMLCanvasElement | null;

  if (wrap && canvas) {
    import('../../scripts/portrait-scene')
      .then((m) => m.init(canvas, wrap.dataset.photo ?? ''))
      .catch((err) => console.error('[portrait-scene] load failed', err));
  }
</script>
