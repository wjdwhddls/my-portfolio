---
/**
 * 책장 컨트롤러 — 책 클릭/키보드/ESC/포커스 트랩/스크롤 락/FLIP 좌표/콘텐츠 inject를 전부 담당.
 *
 * 한 곳에 모은 이유: Astro의 인라인 스크립트는 모듈로 번들링되므로 전역 오염이 없고,
 * 이벤트 위임으로 .bookshelf 단일 노드에 리스너 2개(click/keydown)만 부착하면 충분.
 */
import type { Project } from '../../data/projects';

export interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<script is:inline define:vars={{ projects }}>
(function () {
  // ===== DOM 참조 =====
  const shelf = document.querySelector('.bookshelf');
  const modal = document.getElementById('book-modal');
  if (!shelf || !modal) return;

  const stage = modal.querySelector('.book-modal__stage');
  const dim = modal.querySelector('.book-modal__dim');
  const closeBtn = modal.querySelector('.book-modal__close');
  const cover = modal.querySelector('.book-modal__cover');

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  let activeBookEl = null;
  let lastFocused = null;
  let isOpening = false;

  // 프로젝트 데이터를 인덱스 기반 ID(Book.astro의 bookId와 동일 규칙)로 조회
  const projectMap = new Map(projects.map((p, i) => [`book-${i}`, p]));

  // ===== 콘텐츠 inject =====
  function setText(field, value) {
    const el = modal.querySelector(`[data-field="${field}"]`);
    if (el) el.textContent = value ?? '';
  }

  function renderHighlights(highlights) {
    const ul = modal.querySelector('[data-field="highlights"]');
    if (!ul) return;
    ul.innerHTML = '';
    (highlights || []).forEach((h) => {
      const li = document.createElement('li');
      li.className = 'book-modal__highlight';
      const marker = document.createElement('span');
      marker.className = 'book-modal__highlight-marker';
      marker.setAttribute('aria-hidden', 'true');
      marker.textContent = '▸';
      const text = document.createElement('span');
      text.textContent = h;
      li.append(marker, text);
      ul.appendChild(li);
    });
  }

  function renderChips(field, items, extraClass) {
    const root = modal.querySelector(`[data-field="${field}"]`);
    if (!root) return;
    root.innerHTML = '';
    (items || []).forEach((s) => {
      const chip = document.createElement('span');
      chip.className = `book-modal__chip ${extraClass || ''}`.trim();
      chip.textContent = s;
      root.appendChild(chip);
    });
  }

  function renderLinks(links) {
    const root = modal.querySelector('[data-field="links"]');
    if (!root) return;
    root.innerHTML = '';
    (links || []).forEach((link, i) => {
      const a = document.createElement('a');
      a.href = link.url;
      a.target = '_blank';
      a.rel = 'noopener noreferrer';
      a.className = i === 0 ? 'book-modal__link book-modal__link--primary' : 'book-modal__link';
      a.textContent = link.label;
      root.appendChild(a);
    });
  }

  function applyLeatherVars(project, bookEl) {
    // 표지/속표지에 책등과 동일한 가죽 팔레트 적용 (책에서 그대로 읽어옴)
    const cs = getComputedStyle(bookEl);
    const vars = ['--leather-base', '--leather-deep', '--leather-high', '--gold'];
    vars.forEach((v) => {
      const val = cs.getPropertyValue(v).trim();
      if (val) modal.style.setProperty(v, val);
    });
  }

  function renderContent(project, bookEl) {
    setText('title', project.title);
    setText('summary', project.summary);
    setText('role', project.role);
    setText('context', project.context || '');
    setText('monogram', project.book?.monogram || project.emoji || '');
    setText('cover-title', project.book?.spineTitle || project.title);
    renderHighlights(project.highlights);
    renderChips('stack', project.stack, 'book-modal__chip--stack');
    renderChips('tags', project.tags, 'book-modal__chip--tag');
    renderLinks(project.links);
    applyLeatherVars(project, bookEl);
  }

  // ===== FLIP 좌표 =====
  function captureFrom(bookEl) {
    const rect = bookEl.getBoundingClientRect();
    // stage에 from 좌표를 CSS 변수로 전달 (px 단위)
    stage.style.setProperty('--from-x', `${rect.left + rect.width / 2}px`);
    stage.style.setProperty('--from-y', `${rect.top + rect.height / 2}px`);
    stage.style.setProperty('--from-scale', `${rect.height / 560}`);
  }

  // ===== 스크롤바 폭 보정 =====
  function lockScroll() {
    const sbw = window.innerWidth - document.documentElement.clientWidth;
    document.documentElement.style.setProperty('--sbw', `${sbw}px`);
    document.body.classList.add('has-book-modal');
  }
  function unlockScroll() {
    document.body.classList.remove('has-book-modal');
    document.documentElement.style.removeProperty('--sbw');
  }

  // ===== 포커스 관리 =====
  function focusableEls() {
    return modal.querySelectorAll(
      'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])',
    );
  }
  function onFocusTrap(e) {
    if (e.key !== 'Tab') return;
    const els = Array.from(focusableEls()).filter((el) => el.offsetParent !== null);
    if (!els.length) return;
    const first = els[0];
    const last = els[els.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  }

  // ===== 오픈 =====
  function openBook(bookEl) {
    if (isOpening || modal.open) return;
    const id = bookEl.dataset.projectId;
    const project = projectMap.get(id);
    if (!project) return;

    isOpening = true;
    lastFocused = document.activeElement;
    activeBookEl = bookEl;

    renderContent(project, bookEl);
    captureFrom(bookEl);
    lockScroll();

    bookEl.classList.add('is-active');
    modal.showModal();

    // 더블 rAF: 첫 프레임에 from 상태, 다음 프레임에 is-open으로 transition 트리거
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        modal.classList.add('is-open');
        isOpening = false;
        // 닫기 버튼으로 초기 포커스
        closeBtn?.focus();
      });
    });

    modal.addEventListener('keydown', onFocusTrap);
  }

  // ===== 클로즈 =====
  function closeBook() {
    if (!modal.open) return;
    modal.classList.remove('is-open');
    modal.classList.add('is-closing');

    const finish = () => {
      modal.classList.remove('is-closing');
      try { modal.close(); } catch (_) { /* polyfill 환경 대비 */ }
      modal.removeEventListener('keydown', onFocusTrap);
      activeBookEl?.classList.remove('is-active');
      unlockScroll();
      try { lastFocused && lastFocused.focus(); } catch (_) {}
      activeBookEl = null;
    };

    if (reduceMotion) {
      finish();
    } else {
      // cover의 transition 종료를 신호로 사용 (가장 오래 걸리는 요소)
      const onEnd = (e) => {
        if (e.target !== cover && e.target !== stage) return;
        cover?.removeEventListener('transitionend', onEnd);
        stage?.removeEventListener('transitionend', onEnd);
        finish();
      };
      cover?.addEventListener('transitionend', onEnd);
      stage?.addEventListener('transitionend', onEnd);
      // 안전망: transitionend가 안 오는 경우 대비
      setTimeout(finish, 600);
    }
  }

  // ===== 이벤트 위임 =====
  shelf.addEventListener('click', (e) => {
    const book = e.target.closest('.book');
    if (book && shelf.contains(book)) openBook(book);
  });

  shelf.addEventListener('keydown', (e) => {
    if (e.key !== 'Enter' && e.key !== ' ') return;
    const book = e.target.closest('.book');
    if (book && shelf.contains(book)) {
      e.preventDefault();
      openBook(book);
    }
  });

  closeBtn?.addEventListener('click', closeBook);
  dim?.addEventListener('click', closeBook);

  // ESC: dialog의 cancel 이벤트로 처리 (form cancel 중복 방지)
  modal.addEventListener('cancel', (e) => {
    e.preventDefault();
    closeBook();
  });

  // 리사이즈 중에 열려있으면 FLIP 좌표가 무효 → 닫음
  let resizeTimer = null;
  window.addEventListener('resize', () => {
    if (!modal.open) return;
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(closeBook, 100);
  });
})();
</script>
